# =============================================================================
# AI PR Review — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# --- Application ---
# APP_NAME=ai-pr-review
# DEBUG=false
# CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
# DATABASE_URL=sqlite+aiosqlite:///./data/reviews.db

# --- GitHub ---
# Personal Access Token (classic or fine-grained with public_repo access)
# Leave empty for unauthenticated access (60 req/h limit)
# GITHUB_TOKEN=

# --- DeepSeek LLM ---
# REQUIRED: Your DeepSeek API key
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MAX_TOKENS=8192
# DEEPSEEK_TEMPERATURE=0.1

# --- Rate Limiting ---
# RATE_LIMIT_PER_MINUTE=30

# --- Task ---
# MAX_RETRIES=3
# RETRY_BACKOFF_SECONDS=2.0
